{
    "window.zoomLevel": 0, // Define o zoom padrão
    "workbench.colorTheme": "Dracula", // Configura o tema do vscode
    "breadcrumbs.enabled": true, // Mostra o caminho até o arquivo
    "editor.fontSize": 16, // Tamanho da fonte.
    "editor.lineHeight": 24, // Espaçamento entre uma fonte e outra.
    "editor.fontFamily": "Fira Code", // Família da fonte.
    "editor.fontLigatures": true, //
    "editor.minimap.enabled": false, // Remove o minimapa
    "editor.renderLineHighlight": "none", // Não mostra nenhum marcador da linha
    "editor.formatOnSave": false, // Formata o arquivo quando salvamos o mesmo.
    "editor.rulers": [120], // Cria uma linha indicando que o código não deveria ultrapassar.
    "terminal.integrated.shell.osx": "/bin/zsh", // Define o zsh como terminal default
    "terminal.integrated.fontSize": 14, // Define o tamanho da fonte do terminal.
  }
